# Create workbook
wb <- createWorkbook()
# Add worksheets
addWorksheet(wb, "MARCH")
addWorksheet(wb, "ARCH")
addWorksheet(wb, "Notes")
# Write data
writeData(wb, sheet = "MARCH", x = missing_march_final)
writeData(wb, sheet = "ARCH", x = missing_arch_final)
writeData(wb, sheet = "Notes", x = notes_df)
# Save workbook
saveWorkbook(wb, output_path, overwrite = TRUE)
