mutate(
cohort = "MARCH"
) %>%
mutate(across(everything(), as.character))
# ARCH (Sheet 2)
missing_arch <- read_excel(missing_path, sheet = 2) %>%
mutate(
cohort = "ARCH"
) %>%
mutate(across(everything(), as.character))
# ------------------------------ 4. ID manipulation ----------------------------
arch_bc <- arch_bc %>%
mutate(
