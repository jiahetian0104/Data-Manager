# ARCH Birth Certificate
arch_bc <- read_csv(PATHS$arch_bc, show_col_types = FALSE) %>%
mutate(across(everything(), ~ ifelse(. == "", NA, .)))
# MARCH Birth Certificate
march_bc <- read_csv(PATHS$march_bc, show_col_types = FALSE) %>%
mutate(across(everything(), ~ ifelse(. == "", NA, .)))
# Crosswalk (second sheet for MARCH)
crosswalk_march <- read_excel(PATHS$crosswalk, sheet = 2) %>%
mutate(across(everything(), as.character))
crosswalk_all <- read_excel(PATHS$crosswalk, sheet = 1) %>%
mutate(across(everything(), as.character))
