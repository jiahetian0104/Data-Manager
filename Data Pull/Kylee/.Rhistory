# Load libraries
library(tidyverse)
library(readxl)
# ------------------------------ 2. Define Paths ---------------------------
BASE_PATH <- "Z:/ECHO/CHARM/Data"
PATHS <- list(
arch_bc   = file.path(BASE_PATH, "ECHO 1/MDHHS Data/Birth_Certificate/ARCH_BC_Combined.csv"),
march_bc  = file.path(BASE_PATH, "ECHO 1/MDHHS Data/Birth_Certificate/MARCH_BC_FinalUpd.csv"),
crosswalk = file.path(BASE_PATH, "Miscellaneous/Global Crosswalk/global_crosswalk.xlsx")
)
# ------------------------------ 3. Import Data ----------------------------
