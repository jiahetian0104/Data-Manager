# Create notes sheet
notes_df <- data.frame(
Notes = c(
"1. Data were prepared by Jiahe Tian on March 23, 2026.",
"2. ARCH and MARCH data were obtained from existing CHARM Birth Certificate data.",
"3. Two records from ARCH and two records from MARCH were found in the existing CHARM data."
)
)
