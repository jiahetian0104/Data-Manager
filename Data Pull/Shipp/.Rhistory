# 1. Load library ---------------------------------------------------------
library(tidyverse) # data manipulation
library(writexl) # save xlsx file
library(openxlsx)
# 2. Import Data ----------------------------------------------------------
data <- readxl::read_xlsx("Z:/ECHO/CHARM/Data/Reports/Participant Registration/ParticipantRegistration_Export_01212026.xlsx")
# 3. Data Manipulation ----------------------------------------------------
msu_data <- data %>%
filter(CohortId == "12900") %>% # only consider MSU award
mutate(
EnrollmentDate = coalesce(Cycle2ProtocolEnrollmentDate,
Cycle2ProtocolEnrollmentDatev3_01),
# convert character to Date (month-day-year with time)
EnrollmentDate = mdy_hms(EnrollmentDate),
# drop time, keep only date
EnrollmentDate = as.Date(EnrollmentDate),
# enrollment month
EnrollMonth = format(floor_date(EnrollmentDate, "month"), "%Y-%m")
)
# double check date format
class(msu_data$EnrollmentDate)
# 3. New pregnancies, Partner and Total Children  -------------------------
# get summary for New pregnancies and Total Children
msu_summary_wide <- msu_data %>%
filter(!is.na(EnrollmentDate)) %>%
mutate(
# Create month key like "YYYY-MM"
EnrollMonth = format(floor_date(as.Date(EnrollmentDate), "month"), "%Y-%m"),
# Rename participant types
ParticipantType = case_when(
ParticipantType == "P" ~ "New pregnancies",
ParticipantType == "C" ~ "Total Children",
ParticipantType == "8" ~ "Partners",
TRUE ~ ParticipantType
)
) %>%
group_by(ParticipantType, EnrollMonth) %>%
summarise(
n_participants = n_distinct(EWCP_ParticipantID),  # unique IDs per type-month
.groups = "drop"
) %>%
arrange(EnrollMonth) %>%
pivot_wider(
names_from  = EnrollMonth,
values_from = n_participants,
values_fill = 0
) %>%
arrange(factor(ParticipantType,
levels = c("New pregnancies", "Partners", "Total Children" )))
# 4. Children Details -----------------------------------------------------
# --- 1) Build Date of Birth (DOB) and compute age in months at EnrollmentDate ---
children_age <- msu_data %>%
filter(ParticipantType == "C") %>%   # Keep Children only
mutate(
DOB = make_date(DateOfBirth_Year, DateOfBirth_Month, DateOfBirth_Day),
# Compute completed age in months at EnrollmentDate
age_months = floor(time_length(interval(DOB, EnrollmentDate), "month"))
) %>%
# Drop rows where DOB or EnrollmentDate couldn't be formed
filter(!is.na(age_months) & age_months >= 0)
# --- 3) Bin into the requested age groups (by months thresholds) ---
children_binned <- children_age %>%
mutate(
# Map months to requested bins:
# Infancy (0-<12m), Toddlerhood (12-<36m), 3-<6y (36-<72m),
# 6-<11y (72-<132m), 11-<18y (132-<216m), 18-<21y (216-<252m)
age_group = case_when(
age_months >=   0 & age_months <  12  ~ "Infancy (0-<12 months)",
age_months >=  12 & age_months <  36  ~ "Toddlerhood (12-<3 years)",
age_months >=  36 & age_months <  72  ~ "Ages 3-<6 years",
age_months >=  72 & age_months < 132  ~ "Ages 6-<11 years",
age_months >= 132 & age_months < 216  ~ "Ages 11-<18 years",
age_months >= 216 & age_months < 252  ~ "Ages 18-<21 years",
TRUE ~ NA_character_
),
# Make an ordered factor for nicer sorting
age_group = factor(
age_group,
levels = c(
"Infancy (0-<12 months)",
"Toddlerhood (12-<3 years)",
"Ages 3-<6 years",
"Ages 6-<11 years",
"Ages 11-<18 years",
"Ages 18-<21 years"
),
ordered = TRUE
)
) %>%
filter(!is.na(age_group))
# --- 4) Summarize counts by age_group ---
children_summary <- children_binned %>%
mutate(
# format directly as "YYYY-MM"
EnrollMonth = format(floor_date(EnrollmentDate, "month"), "%Y-%m")
) %>%
group_by(EnrollMonth, age_group) %>%
summarise(
n_participants = n_distinct(EWCP_ParticipantID), # count unique IDs
.groups = "drop"
) %>%
arrange(EnrollMonth, age_group)
children_summary_wide <- children_summary %>%
pivot_wider(
names_from  = EnrollMonth,           # columns = months
values_from = n_participants,        # values = counts
values_fill = 0                      # fill missing with 0
) %>%
arrange(age_group)
# 5. Non-Hispanic White ---------------------------------------------------
msu_data <- msu_data %>%
mutate(
# --- Normalize inputs (trim spaces just in case) ---
Ethnicity_raw = trimws(as.character(Ethnicity)),
Race_raw      = trimws(as.character(Race)),
# --- Recode Ethnicity ---
# -8, 0 -> Not Hispanic or Latino; 1 -> Hispanic or Latino
Ethnicity_rec = case_when(
Ethnicity_raw %in% c("-8", "0", -8, 0) ~ "Not Hispanic or Latino",
Ethnicity_raw %in% c("1", 1)           ~ "Hispanic or Latino",
TRUE                                    ~ NA_character_   # keep others/unknown as NA if any
),
# --- Recode Race ---
# -8, 1 -> White; others -> Non-White
Race_rec = case_when(
Race_raw %in% c("-8", "1", -8, 1) ~ "White",
TRUE                              ~ "Non-White"
),
# --- Construct NHW flags ---
NHW_indicator = if_else(Ethnicity_rec == "Not Hispanic or Latino" & Race_rec == "White", 1L, 0L),
NHW_group     = if_else(NHW_indicator == 1L, "Non-Hispanic White", "Other")
)
# ---- Monthly counts for P and C, other than NHW (NHW_indicator == 0)
monthly_other_than_NHW_long <- msu_data %>%
filter(!is.na(EnrollmentDate)) %>%                 # keep valid dates
filter(ParticipantType %in% c("P", "C")) %>%       # P = pregnancies, C = children
filter(NHW_indicator == 0L) %>%                    # keep non-NHW
mutate(
# Normalize to month for grouping and present as "YYYY-MM"
EnrollMonth = format(floor_date(as.Date(EnrollmentDate), "month"), "%Y-%m")
) %>%
group_by(EnrollMonth, ParticipantType) %>%
summarise(
n = n_distinct(EWCP_ParticipantID),              # count unique new participants
.groups = "drop"
) %>%
arrange(EnrollMonth, ParticipantType)
monthly_other_than_NHW_wide <- monthly_other_than_NHW_long %>%
mutate(
ParticipantType = case_when(
ParticipantType == "P" ~ "New pregnancies other than non-Hispanic White",
ParticipantType == "C" ~ "Children other than non-Hispanic White",
TRUE ~ ParticipantType
)
) %>%
pivot_wider(
names_from  = EnrollMonth,
values_from = n,
values_fill = 0
) %>%
arrange(ParticipantType)
# 6. Combine the tables ---------------------------------------------------
# --- Standardize first column name for merging ---
msu_summary_wide2 <- msu_summary_wide %>%
rename(Category = ParticipantType)
children_summary_wide2 <- children_summary_wide %>%
rename(Category = age_group)
monthly_other_than_NHW_wide2 <- monthly_other_than_NHW_wide %>%
rename(Category = ParticipantType)
# --- Row bind them together ---
final_summary <- bind_rows(
msu_summary_wide2,
children_summary_wide2,
monthly_other_than_NHW_wide2
)
# --- Build empty template with all categories ---
category_order <- c(
"New pregnancies",
"New pregnancies other than non-Hispanic White",
"Partners",
"Infancy (0-<12 months)",
"Toddlerhood (12-<3 years)",
"Ages 3-<6 years",
"Ages 6-<11 years",
"Ages 11-<18 years",
"Ages 18-<21 years",
"Total Children",
"Children other than non-Hispanic White"
)
# --- Extract month columns from final_summary ---
month_cols <- setdiff(names(final_summary), "Category")
# --- Build template with all categories, fill 0 for month columns ---
template <- data.frame(
Category = category_order,
matrix(0, nrow = length(category_order), ncol = length(month_cols))
)
colnames(template)[-1] <- month_cols
# --- Merge existing summary with template ---
final_summary_complete <- bind_rows(final_summary, template) %>%
group_by(Category) %>%
summarise(across(everything(), ~ max(.x, na.rm = TRUE)), .groups = "drop") %>%
mutate(Category = factor(Category, levels = category_order, ordered = TRUE)) %>%
arrange(Category)
View(final_summary_complete)
